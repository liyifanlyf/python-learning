import math  # 导入数学库（虽然本代码未使用复杂函数，但保留以备扩展）

def reward_function(params):
    """
    主奖励函数：兼顾稳定性与速度，已修复所有运行错误
    """
    
    # ====================== 1. 参数读取（AWS官方定义的输入变量）======================
    track_width = params['track_width']                    # 赛道总宽度（单位：米）
    distance_from_center = params['distance_from_center']  # 车辆距离赛道中心线的距离（单位：米）
    all_wheels_on_track = params['all_wheels_on_track'] # 布尔值：True（四轮都在赛道上）/ False（有轮出界）
    steering_angle = abs(params['steering_angle'])       # 转向角绝对值（单位：度，去掉正负号只看大小）
    speed = params['speed']                              # 当前车速（单位：米/秒）
    progress = params['progress']                        # 完成赛道的百分比（0到100）
    waypoints = params['waypoints']                      # 赛道上所有预设的坐标点（用于计算方向）
    closest_waypoints = params['closest_waypoints']      # 距离车辆最近的两个关键点的索引编号
    
    # ====================== 2. 安全底线（一票否决制）======================
    if not all_wheels_on_track:  # 如果检测到有轮子不在赛道上
        return 1e-3  # 立即返回极小值（0.001），告诉模型这是极其严重的错误
    
    # ====================== 3. 居中奖励（防止压线）======================
    track_half_width = track_width / 2.0                 # 计算半宽（从中心线到边缘的距离）
    distance_ratio = distance_from_center / track_half_width  # 计算比例：0=完美居中，1=压在边缘
    
    if distance_ratio > 0.9:  # 如果距离边缘只剩10%的宽度
        return 1e-3  # 直接判死刑，防止车辆试图擦边跑
    
    center_reward = 1.0 - distance_ratio  # 线性奖励：越靠近中心分越高（中心1分，边缘0.1分）
    
    # ====================== 4. 防蛇形奖励（平稳驾驶）======================
    ABS_STEERING_THRESHOLD = 15.0  # 设定转向阈值：15度
    if steering_angle > ABS_STEERING_THRESHOLD:  # 如果方向盘打得过大（超过15度）
        steering_reward = 0.8  # 扣掉20%的奖励，惩罚剧烈摆动
    else:
        steering_reward = 1.0  # 平稳转向，满分奖励
    
    # ====================== 5. 动态速度控制（核心：分地形限速）======================
    next_point_idx = closest_waypoints[1]  # 获取前方最近的检查点索引
    
    # 地形分区（根据你的赛道图片固定布局）
    is_straight = (14 <= next_point_idx <= 61) or (next_point_idx >= 107)  # 直道区域
    is_sharp_turn = (80 <= next_point_idx <= 106)                         # 急弯区域（发卡弯）
    is_medium_turn = (62 <= next_point_idx <= 79) or (1 <= next_point_idx <= 14)  # 缓弯区域
    
    # 速度奖励计算
    if is_straight:  # 如果在直道上
        if speed >= 2.0:  # 如果速度达到2.0m/s以上
            speed_reward = 1.2  # 给1.2倍加成，鼓励全速冲刺
        else:
            speed_reward = speed / 2.0  # 没到2.0按比例给分
    elif is_medium_turn:  # 如果在缓弯
        if speed > 2.3:  # 如果速度过快（>2.3）
            speed_reward = 0.9  # 轻微惩罚
        elif speed > 1.5:  # 如果速度在1.5-2.3之间（最佳过弯速度）
            speed_reward = 1.1  # 额外加分，鼓励积极过弯
        else:
            speed_reward = 0.8  # 太慢了，扣分
    elif is_sharp_turn:  # 如果在急弯
        if speed > 1.8:  # 放宽了原有限速（原1.2），允许更快过弯
            speed_reward = 0.7  # 确实有点快，但还不至于重罚
        elif speed > 1.2:  # 理想区间
            speed_reward = 1.0  # 满分
        else:
            speed_reward = 0.8  # 太保守，扣分
    else:  # 其他区域
        speed_reward = speed / 2.5  # 默认追赶速度
    
    # ====================== 6. 速度稳定性奖励（替代加速度）======================
    stability_reward = 1.0  # 默认满分
    if progress > 0:  # 如果比赛已开始
        # 根据进度估算一个“合理速度”（起步慢，越往后越快）
        expected_speed = 1.0 + (progress / 100.0) * 1.5
        speed_diff = abs(speed - expected_speed)  # 计算实际速度与预期速度的差距
        if speed_diff > 0.5:  # 如果差距过大（急加速或急刹车）
            stability_reward = 0.9  # 轻微惩罚，鼓励平顺驾驶
    
    # ====================== 7. 总奖励加权整合（算总账）======================
    reward = (
        center_reward * 0.45 +        # 中心线权重45%（最重要，别出界）
        steering_reward * 0.1 +       # 转向权重10%（别画龙）
        speed_reward * 0.35 +         # 速度权重35%（核心优化目标）
        stability_reward * 0.1         # 稳定性权重10%（别急刹）
    )
    
    # ====================== 8. 进度加成（鼓励跑完）======================
    if progress % 10 == 0 and progress > 0:  # 每完成10%进度
        reward += progress / 200.0  # 加一点点分（例如30%进度加0.15分）
    
    # ====================== 9. 返回最终奖励======================
    return float(max(reward, 1e-3))  # 确保奖励不会是负数或0