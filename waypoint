        speed_reward = speed / 2.0

elif is_medium_turn:
    # 2. 缓弯：允许高速过弯
    # 原代码惩罚 >2.0 的速度，现在放宽到 2.3
    if speed > 2.3:
        speed_reward = 0.9  # 稍微收敛一点点，防止冲出
    elif speed > 1.5:
        speed_reward = 1.1  # 最佳过弯速度区间，给予奖励
    else:
        speed_reward = 0.8  # 太慢了，扣分

elif is_sharp_turn:
    # 3. 急弯（重点优化区）：大幅提升限速
    # 原代码：>1.2 直接判死刑 (0.2分)
    # 新代码：允许冲到 1.8，鼓励更激进的走线
    if speed > 1.8:
        speed_reward = 0.7  # 确实有点快，但还不至于重罚
    elif speed > 1.2:
        speed_reward = 1.0  # 理想区间，满分鼓励
    else:
        speed_reward = 0.8  # 低于1.2，说明太怂了，扣分

else:
    # 其他过渡区域
    speed_reward = speed / 2.5

# ==========================================================
# 6. 新增：加速度奖励 (Acceleration Bonus)
# 目的：解决 Waypoint 5, 11, 18 等处的“0.5 低速卡顿”
# ==========================================================
acceleration_reward = 1.0
if 'previous_speed' in params:
    acc = speed - params['previous_speed']
    # 如果正在加速（acc > 0），给予额外奖励
    if acc > 0.1:
        acceleration_reward = 1.0 + acc * 0.5  # 加速越快，奖励越多
    # 如果正在严重减速（acc < -0.5），且不在急弯，给予惩罚
    elif acc < -0.5 and not is_sharp_turn:
        acceleration_reward = 0.8

# 保存当前速度，供下一步计算加速度
params['previous_speed'] = speed

# ==========================================================
# 7. 最终速度加权（整合）
# ==========================================================
# 将速度奖励与加速度奖励相乘，形成合力
final_speed_reward = speed_reward * acceleration_reward

