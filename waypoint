#赛车模型
import math

def reward_function(params):
    """
    主奖励函数入口。
    这是模型的"大脑"，每一步都会调用这个函数来决定动作的优劣。
    """

    # ==========================================================
    # 1. 参数读取 (Input Parameters)
    # 从 AWS DeepRacer 仿真环境中获取当前车辆的状态数据
    # ==========================================================
    
    # 车辆四个轮子是否都在赛道上（布尔值：True/False）
    all_wheels_on_track = params['all_wheels_on_track']
    
    # 当前速度（米/秒）
    speed = params['speed']
    
    # 距离赛道中心线的距离（米）
    distance_from_center = params['distance_from_center']
    
    # 赛道的总宽度（米）
    track_width = params['track_width']
    
    # 当前的转向角度（度），正数右转，负数左转
    steering_angle = params['steering_angle']
    
    # 最近的两个检查点索引（用于判断当前位置）
    closest_waypoints = params['closest_waypoints']
    
    # 当前完成的进度百分比 (0-100)
    progress = params['progress']

    # ==========================================================
    # 2. 安全底线 (Safety First)
    # 设计思路：这是一票否决制。只要掉下去，奖励直接归零。
    # ==========================================================
    
    # 如果轮子不在赛道上（冲出赛道）
    if not all_wheels_on_track:
        # 返回一个极小的数，告诉模型：这个动作非常糟糕！
        return 1e-4  # 等于 0.0001

    # ==========================================================
    # 3. 居中奖励 (Stay in the Center)
    # 设计思路：使用线性惩罚。越靠边，分数越低。
    # ==========================================================
    
    # 计算赛道半宽
    track_half_width = track_width / 2.0
    
    # 计算当前位置占赛道半宽的比例 (0=中心, 1=边缘)
    distance_ratio = distance_from_center / track_half_width
    
    # 硬性边界检查：如果距离边缘小于10%的缓冲带，直接重罚
    # 这样可以防止车辆试图蹭着边缘跑
    if distance_ratio > 0.9:
        return 1e-3  # 比掉下去好一点，但还是很差
        
    # 线性奖励：在中心得1分，在0.9处得0.1分
    center_reward = 1.0 - distance_ratio

    # ==========================================================
    # 4. 防蛇形走位 (Anti-Zigzag)
    # 设计思路：大角度转向通常是"之"字形的根源，必须惩罚。
    # ==========================================================
    
    # 取转向角的绝对值，我们只关心转了多少度，不关心方向
    abs_steering = abs(steering_angle)
    
    # 根据转向幅度给予折扣因子
    if abs_steering > 20:
        # 急转弯：奖励打5折（模型会尽量避免这种情况）
        steering_factor = 0.5
    elif abs_steering > 10:
        # 中等转弯：轻微打折
        steering_factor = 0.8
    else:
        # 直行或小角度微调：满分
        steering_factor = 1.0

    # ==========================================================
    # 5. 动态速度控制 (Dynamic Speed Control)
    # 设计思路：利用已知的赛道地图（Checkpoint Index）来限速。
    # ==========================================================
    
    # 获取前方检查点索引
    next_point_idx = closest_waypoints[1]
    
    # --- 地形分区定义 (基于赛道图片分析) ---
    # 直道区域：赛道中间的长直道
    is_straight = (14 <= next_point_idx <= 61) or (next_point_idx >= 107)
    # 急弯区域：最难的发卡弯 (80-106)
    is_sharp_turn = (80 <= next_point_idx <= 106)
    # 缓弯区域：剩下的弯道
    is_medium_turn = (62 <= next_point_idx <= 79) or (1 <= next_point_idx <= 14)

    # --- 分段奖励逻辑 ---
    if is_straight:
        # 直道：鼓励全速冲刺 (最高2.5)
        # 速度越快，得分越高 (speed/2.5)
        speed_reward = speed / 2.5
        
    elif is_sharp_turn:
        # 急弯：必须减速！
        # 如果速度超过1.2，给极低奖励；否则给0.8分
        # 这里故意不设高分，因为急弯求稳不求快
        if speed > 1.2:
            speed_reward = 0.2
        else:
            speed_reward = 0.8
            
    elif is_medium_turn:
        # 缓弯：允许稍快一点
        if speed > 2.0:
            speed_reward = 0.5
        else:
            speed_reward = speed / 2.0
            
    else:
        # 其他情况默认处理
        speed_reward = speed / 2.5

    # ==========================================================
    # 6. 最终加权计算 (Final Calculation)
    # 设计思路：加权求和，速度最重要，居中次之。
    # ==========================================================
    
    total_reward = (
        speed_reward * 0.5 +      # 速度占 50% 权重
        center_reward * 0.4 +     # 居中占 40% 权重
        steering_factor * 0.1     # 平滑占 10% 权重
    )

    # 确保奖励不为负，且不低于最低值
    return float(max(total_reward, 1e-3))

